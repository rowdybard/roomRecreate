# Room Recreator — all variables are OPTIONAL.
# The app runs fully without any of these (deterministic generation + localStorage).

# --- OpenAI (server-only). Powers /api/generate-kit (text) AND
#     /api/restyle-room (gpt-image-1 photo restyle). Required for room restyle. ---
OPENAI_API_KEY=

# --- Public app URL used for building shareable /kit/[id] links. ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe payment link for the "Get Full Kit — $9" button. ---
# If empty, the button shows a "Checkout coming soon" toast.
NEXT_PUBLIC_STRIPE_FULL_KIT_URL=

# --- Supabase (optional). If set, storage.ts can persist kits/emails to a DB. ---
# If empty, kits + email leads are saved to localStorage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
